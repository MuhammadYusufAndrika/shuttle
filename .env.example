APP_NAME="Shuttle Dahana"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://shuttle.dahana.local
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=daily
LOG_LEVEL=warning

# ── Database ────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shuttle_dahana
DB_USERNAME=shuttle
DB_PASSWORD=GANTI_PASSWORD_AMAN

# ── Cache & Session ─────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true

# ── Queue ───────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Broadcasting (Laravel Reverb) ───────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=GANTI_APP_ID
REVERB_APP_KEY=GANTI_APP_KEY
REVERB_APP_SECRET=GANTI_APP_SECRET
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="shuttle.dahana.local"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ── Web Push Notifications (VAPID) ──────────────────────────────────
# Generate dengan: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=ISI_PUBLIC_KEY_DARI_KEYGEN
VAPID_PRIVATE_KEY=ISI_PRIVATE_KEY_DARI_KEYGEN
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# ── Mail ────────────────────────────────────────────────────────────
MAIL_MAILER=log
